# ============================================================
# LearnCode AI Backend — Environment Variables
# Copy this file to .env for local dev. On Railway, paste each
# key into the project's "Variables" tab.
# ============================================================

# --- Server ---
NODE_ENV=development                       # production on Railway
PORT=5000                                  # Railway injects PORT, leave blank in prod
FRONTEND_URL=http://localhost:5173         # local dev
FRONTEND_URLS=                             # comma-separated for prod, e.g. https://learncode-ai.vercel.app,https://www.your-domain.com

# --- Database ---
MONGODB_URI=                               # mongodb+srv://USER:PASS@cluster.xxxx.mongodb.net/learncode?retryWrites=true&w=majority

# --- Auth secrets (REQUIRED in production — generate with: openssl rand -hex 32) ---
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7
SESSION_SECRET=

# --- OAuth (optional; leave blank to disable a provider) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Email (Nodemailer) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=                                # use a Gmail "App Password", not your real password
EMAIL_FROM_NAME=LearnCode AI
EMAIL_FROM=

# --- AI providers ---
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Code execution backend ---
# docker (default, local dev) | piston (Railway / no-Docker hosts) | fallback (in-process, last resort)
CODE_EXEC_BACKEND=docker
PISTON_URL=https://emkc.org/api/v2/piston   # only used when CODE_EXEC_BACKEND=piston
CODE_EXEC_TIMEOUT_MS=10000
