{
  "name": "learncode-ai-backend",
  "version": "1.0.0",
  "description": "Backend for LearnCode AI platform built on nodejs using express",
  "license": "ISC",
  "author": "asad-ullah-turab",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "watch": "nodemon src/server.js",
    "test": "cross-env NODE_ENV=test NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "cross-env NODE_ENV=test NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "cross-env NODE_ENV=test NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:unit": "cross-env NODE_ENV=test NODE_OPTIONS='--experimental-vm-modules' jest tests/unit",
    "test:integration": "cross-env NODE_ENV=test NODE_OPTIONS='--experimental-vm-modules' jest tests/integration",
    "test:business": "cross-env NODE_ENV=test NODE_OPTIONS='--experimental-vm-modules' jest tests/business",
    "test:functional": "cross-env NODE_ENV=test NODE_OPTIONS='--experimental-vm-modules' jest tests/functional",
    "seed:courses": "node scripts/seedCourses.js",
    "docker:secure": "docker-compose -f docker-compose.secure.yml up -d",
    "docker:fallback": "docker-compose -f docker-compose.fallback.yml up -d",
    "docker:security-check": "powershell -ExecutionPolicy Bypass -File scripts/windows/docker-network-fix.ps1",
    "docker:build-secure": "docker-compose -f docker-compose.secure.yml build",
    "docker:build-fallback": "docker-compose -f docker-compose.fallback.yml build",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "security:audit": "npm audit && docker scout cves || echo 'Docker Scout not available'",
    "security:scan": "powershell -ExecutionPolicy Bypass -File scripts/windows/docker-security-enhanced.ps1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dockerode": "^4.0.9",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.3",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.6",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.13.0",
    "validator": "^13.15.15",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@shelf/jest-mongodb": "^5.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.36.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.4",
    "nodemon": "^3.1.10",
    "supertest": "^6.3.4"
  }
}
